{
  "name": "react-autocomplete-france",
  "description": "React components for France Address Gouv Autocomplete",
  "private": false,
  "version": "2.0.0",
  "type": "module",
  "author": "Clément de Louvencourt <clement@meilleursbiens.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cldt-fr/react-autocomplete-france.git"
  },
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js"
    }
  },
  "main": "./dist/index.umd.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc && vite build",
    "dev": "npm start",
    "start": "storybook dev -p 6006",
    "storybook": "npm start",
    "build-docs": "storybook build -o docs && touch ./docs/.nojekyll",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/addon-interactions": "^8.6.0",
    "@storybook/addon-links": "^8.6.0",
    "@storybook/blocks": "^8.6.0",
    "@storybook/react": "^8.6.0",
    "@storybook/react-vite": "^8.6.0",
    "@storybook/test": "^8.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.5.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^8.6.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^4.5.0"
  },
  "files": [
    "dist"
  ]
}
